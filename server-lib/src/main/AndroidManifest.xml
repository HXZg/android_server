<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.REBOOT" />

    <application>
        <!-- Ktor Server Service - 运行在独立进程 -->
        <service
            android:name=".KtorServerService"
            android:enabled="true"
            android:exported="false"
            android:process=":server"
            android:foregroundServiceType="dataSync" />

        <!-- 接收服务进程的广播 -->
        <receiver
            android:name=".RestartReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.androidserver.ACTION_RESTART_APP" />
                <action android:name="com.androidserver.ACTION_SERVER_STARTED" />
                <action android:name="com.androidserver.ACTION_SERVER_STOPPED" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.androidserver.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/androidserver_file_paths" />
        </provider>
    </application>

</manifest>
